class TreeNode:
    def __init__(self, data , designation):
        self.designation = designation
        self.data = data
        self.children = []
        self.parent = None

    def add_child(self,child):
        child.parent = self
        self.children.append(child)

    def print_tree(self , name):
        l = self.level() * "   "
        s = "|__" if self.parent else ""
        if name == "name":
            print(l+s + self.data)
        elif name == "designation":
            print(l +s+ self.designation)
        else :
            print(l + s+self.data,"(",self.designation,")" )
        if self.children:
            for child in self.children:
                child.print_tree(name)

    def level(self):
        level = 0
        p = self.parent
        while(p):
            level += 1
            p = p.parent
        return level

