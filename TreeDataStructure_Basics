class TreeNode:
    def __init__(self , data):
        self.data = data
        self.children = []
        self.parent = None

    def get_level(self):
        level = 0
        current = self.parent
        while current:
            level +=1
            current = current.parent
        return level

    def print_tree(self):
        print((self.get_level() * "      ")+ self.data)
        if self.children:
            for child in self.children:
                child.print_tree()

    def add_child(self, child):
        child.parent = self
        self.children.append(child)



