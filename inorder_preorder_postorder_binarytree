class BinarySearchTree:
    def __init__(self,data):
        self.data = data
        self.left = None
        self.right = None

    def add_child(self, data):
        #donot add if child is duplicate
        if data == self.data:
            return
        # add on the left node
        elif data < self.data:
            if self.left:
                self.left.add_child(data)
            else:
                self.left = BinarySearchTree(data)
        else:
            if self.right:
                self.right.add_child(data)
            else:
                self.right = BinarySearchTree(data)

    def display(self, level=0, prefix="Root: "):
        print(" " * (level * 4) + prefix + str(self.data))
        if self.left:
            self.left.display(level + 1, "L--- ")
        if self.right:
            self.right.display(level + 1, "R--- ")

    def inorder_traversal(self):
        element_list = []
        if self.left:
            element_list += self.left.inorder_traversal()
        element_list.append(self.data)
        if self.right:
            element_list += self.right.inorder_traversal()

        return element_list

    def preorder_traversal(self):
        element_list = []
        element_list.append(self.data)
        if self.left:
            element_list += self.left.preorder_traversal()
        if self.right:
            element_list+= self.right.preorder_traversal()
        return element_list

    def postorder_traversal(self):
        element_list = []
        if self.left:
            element_list += self.left.postorder_traversal()
        if self.right:
            element_list += self.right.postorder_traversal()
        element_list.append(self.data)
        return element_list

    def find_min(self):
        if self.left == None:
            return self.data
        else:
            return self.left.find_min()

    def find_max(self):
        if self.right == None:
            return self.data
        else:
            return self.right.find_max()

    def total_sum(self):
        left_sum = self.left.total_sum() if self.left else 0
        right_sum = self.right.total_sum() if self.right else 0
        return self.data + left_sum + right_sum

def build_tree(elementlist):
    rootnode = BinarySearchTree(elementlist[0])
    for element in range(1, len(elementlist)):
        rootnode.add_child(elementlist[element])
    return rootnode



numbers = [2, 3, 6, 5, 1, 7, 9, 4]
tree = build_tree(numbers)
tree.display()
sorted_list = tree.inorder_traversal()
print(f"Smallest number is sorted_list is : {tree.find_min()}")
print(f"Largest number is sorted list is : {tree.find_max()}")
print(f"Sum of all the elements is {tree.total_sum()} ")
print(tree.preorder_traversal())
print(tree.postorder_traversal())



